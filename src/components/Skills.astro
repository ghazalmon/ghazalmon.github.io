---
const skillGroups = [
  {
    title: 'Project Management',
    skills: ['Project Planning & Execution', 'Timeline & Resource Management', 'PMP Methodology', 'Workflow Optimization', 'Deliverable Tracking'],
  },
  {
    title: 'Collaboration',
    skills: ['Cross-Functional Team Coordination', 'Stakeholder Communication', 'Onboarding Support', 'Process Improvement'],
  },
  {
    title: 'Technical',
    skills: ['Microfluidics & Microsystems', 'Prototyping & Fabrication', 'Quality Assurance & Testing', 'Biomedical Engineering', 'Cell Culture Techniques'],
  },
  {
    title: 'Entrepreneurship',
    skills: ['Pitching & Presentation', 'Early-Stage Startups', 'Technology Commercialization', 'Innovation Strategy'],
  },
];
---

<section id="skills" class="py-20 px-6 bg-white">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-slate-900 mb-2">Skills</h2>
    <div class="w-12 h-1 bg-teal-500 rounded mb-10"></div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {skillGroups.map((group) => (
        <div>
          <h3 class="text-sm font-semibold text-teal-700 uppercase tracking-wider mb-4">{group.title}</h3>
          <ul class="space-y-2.5">
            {group.skills.map((skill) => (
              <li class="text-slate-600 text-sm flex items-start gap-2">
                <svg class="w-4 h-4 text-teal-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
