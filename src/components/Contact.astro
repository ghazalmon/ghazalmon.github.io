---
import content from '../content/site-content.json';
const { headline, text, linkedin } = content.contact;
---

<section id="contact" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-slate-900 mb-2">{headline}</h2>
    <div class="w-12 h-1 bg-teal-500 rounded mb-4"></div>
    <p class="text-slate-600 mb-10 max-w-lg">
      {text}
    </p>
    <div class="grid sm:grid-cols-2 gap-6 max-w-md">
        <a
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-5 rounded-xl border border-slate-200 hover:border-teal-300 transition-colors group"
        >
          <div class="w-10 h-10 rounded-full bg-teal-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-teal-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <p class="text-sm font-medium text-slate-900 group-hover:text-teal-700 transition-colors">LinkedIn</p>
        </a>
        <a
          id="email-link"
          href="#"
          class="flex items-center gap-4 p-5 rounded-xl border border-slate-200 hover:border-teal-300 transition-colors group"
        >
          <div class="w-10 h-10 rounded-full bg-teal-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="text-sm font-medium text-slate-900 group-hover:text-teal-700 transition-colors">Email</p>
        </a>
    </div>
  </div>
</section>

<script>
  const u = 'grab.brides_0k';
  const d = 'icloud.com';
  const addr = `${u}@${d}`;
  const link = document.getElementById('email-link');
  if (link) link.setAttribute('href', `mailto:${addr}`);
</script>
