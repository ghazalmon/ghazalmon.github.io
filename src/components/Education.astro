---
import content from '../content/site-content.json';
const education = content.education;
---

<section id="education" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-slate-900 mb-2">Education</h2>
    <div class="w-12 h-1 bg-teal-500 rounded mb-10"></div>
    <div class="grid sm:grid-cols-2 gap-6">
      {education.map((edu) => (
        <div class="p-5 rounded-xl border border-slate-200 hover:border-teal-300 transition-colors bg-white">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-semibold text-slate-900">{edu.school}</h3>
              <p class="text-slate-600 text-sm mt-1">{edu.degree}</p>
            </div>
            {edu.period && (
              <span class="text-xs text-slate-400 font-medium whitespace-nowrap ml-4">{edu.period}</span>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
