---
import content from '../content/site-content.json';
const { paragraphs, certification, location, languages, interests } = content.about;
---

<section id="about" class="py-20 px-6 bg-white">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-slate-900 mb-2">About</h2>
    <div class="w-12 h-1 bg-teal-500 rounded mb-8"></div>
    <div class="grid md:grid-cols-3 gap-10">
      <div class="md:col-span-2">
        {paragraphs.map((p) => (
          <p class="text-slate-600 leading-relaxed mb-4">{p}</p>
        ))}
      </div>
      <div class="space-y-5">
        <div>
          <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Certification</h3>
          <p class="text-slate-700 font-medium">{certification}</p>
        </div>
        <div>
          <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Location</h3>
          <p class="text-slate-700 font-medium">{location}</p>
        </div>
        <div>
          <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Languages</h3>
          <div class="flex flex-wrap gap-2">
            {languages.map((lang) => (
              <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-full text-sm">{lang}</span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Interests</h3>
          <div class="flex flex-wrap gap-2">
            {interests.map((interest) => (
              <span class="px-3 py-1 bg-teal-50 text-teal-700 rounded-full text-sm">{interest}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
