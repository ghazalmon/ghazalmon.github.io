---
const publications = [
  {
    title: 'Microfluidic and Lab on-a-Chip Systems for Cutaneous Wound Healing Studies',
  },
  {
    title: 'An on-chip wound healing assay fabricated by xurography for evaluation of dermal fibroblast cell migration and wound closure',
  },
];
---

<section class="py-20 px-6 bg-white">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-slate-900 mb-2">Publications</h2>
    <div class="w-12 h-1 bg-teal-500 rounded mb-10"></div>
    <div class="space-y-4">
      {publications.map((pub) => (
        <div class="flex items-start gap-3 p-4 rounded-lg bg-slate-50 border border-slate-100">
          <svg class="w-5 h-5 text-teal-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <p class="text-slate-700 text-sm leading-relaxed">{pub.title}</p>
        </div>
      ))}
    </div>
  </div>
</section>
