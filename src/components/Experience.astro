---
const jobs = [
  {
    company: 'Sarcura GmbH',
    role: 'Development Engineer Microsystems',
    period: 'Feb 2022 — Nov 2024',
    bullets: [
      'Took ownership of tracking timelines, tasks, and deliverables, helping the team meet fabrication deadlines consistently.',
      'Contributed to the fabrication of 200+ microfluidic chips, supporting continuous prototyping of a cell sorting platform for cell therapy applications.',
      'Conducted thorough testing and evaluation of prototypes and complete systems, ensuring quality standards.',
      'Led project planning and execution, managing timelines and resources for successful outcomes.',
      'Collaborated with cross-functional teams to align project goals and enhance development processes.',
    ],
  },
  {
    company: 'Vienna University of Technology',
    role: 'Project Assistant',
    period: 'Mar 2020 — Jan 2022',
    bullets: [
      'Designed and fabricated a wound healing-on-a-chip system for biomedical applications.',
      'Conducted rigorous testing, evaluation, and optimization of prototypes to enhance functionality.',
      'Utilized cell culture techniques to support experimental validation and system development.',
      'Developed strong project management and organizational skills navigating academic research processes.',
    ],
  },
  {
    company: 'TU Wien Innovation Incubation Center (i²c)',
    role: 'Innovation & Startup Programs Participant',
    period: '2021',
    bullets: [
      'Selected for the Technology Leveraging Workshop (Bootcamp for Scientists) focused on translating scientific ideas into real-world applications.',
      'Awarded two Best Pitch prizes (€5,000 + Wild Card) for an innovative project recognized for clarity and impact.',
    ],
  },
];
---

<section id="experience" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-slate-900 mb-2">Experience</h2>
    <div class="w-12 h-1 bg-teal-500 rounded mb-10"></div>
    <div class="relative">
      <div class="absolute left-[7px] top-2 bottom-2 w-px bg-slate-200 hidden md:block"></div>
      <div class="space-y-12">
        {jobs.map((job) => (
          <div class="relative md:pl-10">
            <div class="absolute left-0 top-2 w-[15px] h-[15px] rounded-full border-[3px] border-teal-500 bg-white hidden md:block"></div>
            <div>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
                <h3 class="text-lg font-semibold text-slate-900">{job.role}</h3>
                <span class="text-sm text-slate-400 font-medium">{job.period}</span>
              </div>
              <p class="text-teal-700 font-medium text-sm mb-3">{job.company}</p>
              <ul class="space-y-2">
                {job.bullets.map((b) => (
                  <li class="text-slate-600 text-sm leading-relaxed pl-4 relative before:absolute before:left-0 before:top-[10px] before:w-1.5 before:h-1.5 before:bg-slate-300 before:rounded-full">
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
