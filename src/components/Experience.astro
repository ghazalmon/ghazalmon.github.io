---
import content from '../content/site-content.json';
const jobs = content.experience;
---

<section id="experience" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-slate-900 mb-2">Experience</h2>
    <div class="w-12 h-1 bg-teal-500 rounded mb-10"></div>
    <div class="relative">
      <div class="absolute left-[7px] top-2 bottom-2 w-px bg-slate-200 hidden md:block"></div>
      <div class="space-y-12">
        {jobs.map((job) => (
          <div class="relative md:pl-10">
            <div class="absolute left-0 top-2 w-[15px] h-[15px] rounded-full border-[3px] border-teal-500 bg-white hidden md:block"></div>
            <div>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
                <h3 class="text-lg font-semibold text-slate-900">{job.role}</h3>
                <span class="text-sm text-slate-400 font-medium">{job.period}</span>
              </div>
              <p class="text-teal-700 font-medium text-sm mb-3">{job.company}</p>
              <ul class="space-y-2">
                {job.bullets.map((b) => (
                  <li class="text-slate-600 text-sm leading-relaxed pl-4 relative before:absolute before:left-0 before:top-[10px] before:w-1.5 before:h-1.5 before:bg-slate-300 before:rounded-full">
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
