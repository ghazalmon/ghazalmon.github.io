---
const links = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#skills', label: 'Skills' },
  { href: '#education', label: 'Education' },
  { href: '#contact', label: 'Contact' },
];
---

<nav class="fixed top-0 w-full bg-white/80 backdrop-blur-md border-b border-slate-200/60 z-50">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <div class="w-16"></div>
    <div class="hidden md:flex items-center gap-8">
      {links.map(({ href, label }) => (
        <a href={href} class="text-sm text-slate-600 hover:text-teal-700 transition-colors">
          {label}
        </a>
      ))}
      <a
        href="/cv-ghazal-monfared.pdf"
        download
        class="text-sm font-medium text-teal-700 border border-teal-600 rounded-full px-4 py-1.5 hover:bg-teal-600 hover:text-white transition-colors"
      >
        Download CV
      </a>
    </div>
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-slate-600"
      aria-label="Toggle menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200/60 bg-white/95 backdrop-blur-md">
    <div class="px-6 py-4 flex flex-col gap-3">
      {links.map(({ href, label }) => (
        <a href={href} class="text-sm text-slate-600 hover:text-teal-700 transition-colors py-1">
          {label}
        </a>
      ))}
      <a
        href="/cv-ghazal-monfared.pdf"
        download
        class="text-sm font-medium text-teal-700 border border-teal-600 rounded-full px-4 py-1.5 hover:bg-teal-600 hover:text-white transition-colors text-center mt-1"
      >
        Download CV
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
